#!/usr/bin/env bash
set -euo pipefail

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
if [[ -z "${staged_files}" ]]; then
  exit 0
fi

blocked_file_pattern='(^|/)(\.env($|\..+)|[^/]+\.env($|\..+)|\.envrc|garmin_tokens\.json|[^/]+\.(pem|key|p12|pfx))$'
blocked_files="$(printf '%s\n' "${staged_files}" | grep -E "${blocked_file_pattern}" | grep -Ev '\.example$' || true)"
if [[ -n "${blocked_files}" ]]; then
  echo "Commit blocked: staged filenames look like env files or private key material." >&2
  printf '%s\n' "${blocked_files}" >&2
  exit 1
fi

secret_pattern='-----BEGIN (RSA|OPENSSH|EC|DSA|PGP|ENCRYPTED) PRIVATE KEY-----|AKIA[0-9A-Z]{16}|ASIA[0-9A-Z]{16}|AIza[0-9A-Za-z_-]{35}|ghp_[A-Za-z0-9]{20,}|github_pat_[A-Za-z0-9_]{20,}|xox[baprs]-[A-Za-z0-9-]{10,}|sk-[A-Za-z0-9]{20,}|eyJ[A-Za-z0-9_-]{10,}\.[A-Za-z0-9._-]{10,}\.[A-Za-z0-9._-]{10,}|(API_KEY|SECRET_KEY|ACCESS_KEY|AUTH_TOKEN|TOKEN|PASSWORD)[A-Z_]*[[:space:]]*[:=][[:space:]]*["'"'"']?[A-Za-z0-9/_+=.-]{16,}'
allowed_placeholder_pattern='your_key_here|example|example_key|placeholder|changeme|sk-\.\.\.|<token>|<path>|tokenstore='

added_lines="$(git diff --cached --unified=0 --no-color --diff-filter=ACMR | grep -E '^\+[^+]' || true)"
matches="$(printf '%s\n' "${added_lines}" | grep -E -- "${secret_pattern}" | grep -Evi -- "${allowed_placeholder_pattern}" || true)"
if [[ -n "${matches}" ]]; then
  echo "Commit blocked: possible secret detected in staged changes." >&2
  printf '%s\n' "${matches}" >&2
  exit 1
fi
